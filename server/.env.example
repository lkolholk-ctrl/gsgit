# Скопируй в .env и заполни. .env в git не коммитить.

# Секрет вебхука — придумай длинную случайную строку (openssl rand -hex 32)
# и укажи ЕЁ ЖЕ в настройках GsGit App на GitHub (Webhook secret).
GITHUB_WEBHOOK_SECRET=

# ID Firebase-проекта (Firebase Console -> Project settings -> Project ID).
FCM_PROJECT_ID=

# Путь внутри контейнера к ключу сервисного аккаунта Firebase.
# Файл положи в server/data/service-account.json (папка монтируется как /data).
SERVICE_ACCOUNT_FILE=/data/service-account.json
