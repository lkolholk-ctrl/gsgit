# TLS-сертификаты Caddy выпускает и продлевает сам (Let's Encrypt).
# Поменяй домены здесь, если зона будет другой.

# Опциональный поддомен личного XHTTP-узла (генерит xray-setup.sh).
# Пока сниппета нет — import ничего не подключает, стек работает как обычно.
import /etc/caddy/conf.d/*.caddy

gsgit.org {
	root * /srv/site
	file_server
}

api.gsgit.org {
	reverse_proxy api:8080
}

status.gsgit.org {
	reverse_proxy kuma:3001
}
