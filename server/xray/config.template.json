{
  "log": { "loglevel": "warning" },
  "inbounds": [
    {
      "listen": "0.0.0.0",
      "port": 2000,
      "protocol": "vless",
      "settings": {
        "clients": [ { "id": "__UUID__" } ],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "xhttp",
        "xhttpSettings": {
          "path": "/",
          "mode": "auto",
          "scMaxEachPostBytes": 1000000,
          "xPaddingBytes": "100-1100"
        }
      }
    }
  ],
  "outbounds": [
    { "protocol": "freedom", "tag": "direct" }
  ]
}
