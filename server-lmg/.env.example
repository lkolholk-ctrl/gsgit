# LMG server (ICM broker). Скопируй в .env и заполни. В код секреты НЕ зашивать.
LMG_PORT=8090
ICM_BASE_URL=https://byicloud.online/api/partner
ICM_PARTNER_KEY=            # ключ с https://byicloud.online/partners — ГЛАВНЫЙ и ЕДИНСТВЕННЫЙ обязательный секрет
ICM_ORIGIN=https://liquid.glassfiles.ru   # наш origin, уже в whitelist ICM; сервер шлёт его на upstream
TELEGRAM_BOT_TOKEN=         # НЕ нужен. Оставить пустым. Заполнять только если решишь включить HMAC-проверку Telegram
LMG_DATA_DIR=/data
# LMG_ADMIN_KEY=            # необязательно; иначе сгенерится в /data/lmg-admin.key
