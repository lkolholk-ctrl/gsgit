# LMG server (ICM broker). Скопируй в .env и заполни. В код секреты НЕ зашивать.
LMG_PORT=8090
ICM_BASE_URL=https://byicloud.online/api/partner
ICM_PARTNER_KEY=            # ключ с https://byicloud.online/partners — ГЛАВНЫЙ секрет
TELEGRAM_BOT_TOKEN=         # токен @byicmbot (валидация Telegram Login)
LMG_DATA_DIR=/data
# LMG_ADMIN_KEY=            # необязательно; иначе сгенерится в /data/lmg-admin.key
